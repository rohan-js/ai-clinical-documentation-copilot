# Required Environment Variables for Backend Deployment
# Copy this file to .env and fill in your values

# Groq API Key (required) - Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Whisper Model (optional) - Options: tiny, base, small, medium, large
# Use 'tiny' for free tier hosting with memory constraints
WHISPER_MODEL=small
